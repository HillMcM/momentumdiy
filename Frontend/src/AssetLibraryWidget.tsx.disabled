import { useState, useRef } from 'react';
import type { Asset, BrandingKit, ShareLink } from './types';

interface AssetLibraryWidgetProps {
  assets: Asset[];
  brandingKits: BrandingKit[];
  shareLinks: ShareLink[];
  onAssetsChange: (assets: Asset[]) => void;
  onBrandingKitsChange: (kits: BrandingKit[]) => void;
  onShareLinksChange: (links: ShareLink[]) => void;
  onNavigateToAssetLibrary: () => void;
}

export default function AssetLibraryWidget({ 
  assets, 
  brandingKits, 
  shareLinks, 
  onAssetsChange,
  onBrandingKitsChange,
  onShareLinksChange,
  onNavigateToAssetLibrary 
}: AssetLibraryWidgetProps) {
  const [showQuickUpload, setShowQuickUpload] = useState(false);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const recentAssets = assets.slice(0, 5);
  const totalAssets = assets.length;
  const totalKits = brandingKits.length;
  const totalLinks = shareLinks.length;
  const activeShares = shareLinks.filter(link => link.isActive).length;

  const getCategoryIcon = (category: string) => {
    const icons: { [key: string]: string } = {
      logos: '🎨',
      images: '🖼️',
      documents: '📄',
      videos: '🎥',
      fonts: '🔤',
      colors: '🎨',
      templates: '📋',
      other: '📁'
    };
    return icons[category] || '📁';
  };

  const formatFileSize = (bytes: number) => {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  };

  const handleFileUpload = async (event: React.ChangeEvent<HTMLInputElement>) => {
    const files = event.target.files;
    if (!files) return;

    const newAssets: Asset[] = Array.from(files).map((file, index) => {
      // Auto-categorize based on file type
      let category = 'other';
      if (file.type.startsWith('image/')) {
        category = 'images';
      } else if (file.type.includes('pdf') || file.type.includes('document') || file.type.includes('text')) {
        category = 'documents';
      } else if (file.type.startsWith('video/')) {
        category = 'videos';
      } else if (file.type.includes('font') || file.name.toLowerCase().includes('.ttf') || file.name.toLowerCase().includes('.otf')) {
        category = 'fonts';
      } else if (file.name.toLowerCase().includes('logo') || file.name.toLowerCase().includes('brand')) {
        category = 'logos';
      } else if (file.name.toLowerCase().includes('template') || file.name.toLowerCase().includes('layout')) {
        category = 'templates';
      }

      return {
        id: Date.now().toString() + '-' + index,
        name: file.name,
        description: `Uploaded from dashboard: ${category} file`,
        category,
        fileType: file.type,
        fileSize: file.size,
        uploadDate: new Date(),
        url: URL.createObjectURL(file),
        tags: [category, 'dashboard-upload'],
        isPublic: false
      };
    });

    // Update local state immediately for UI responsiveness
    onAssetsChange([...assets, ...newAssets]);
    setShowQuickUpload(false);
  };

  return (
    <div className="widget" style={{ 
      background: '#22202F',
      borderRadius: '16px',
      padding: '1.5rem',
      border: '1px solid rgba(255, 255, 255, 0.1)',
      color: '#FFF1E7',
      height: '100%',
      display: 'flex',
      flexDirection: 'column'
    }}>
      {/* Header */}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '1.5rem' }}>
        <div>
          <h2 style={{ margin: 0, fontSize: '1.5rem', fontWeight: 600, color: '#FFF1E7' }}>
            Asset Library
          </h2>
          <p style={{ margin: '0.25rem 0 0 0', fontSize: '0.875rem', color: '#FFF1E7', opacity: 0.7 }}>
            Manage your business assets
          </p>
        </div>
        <button
          onClick={onNavigateToAssetLibrary}
          style={{
            background: '#EF8E81',
            color: '#FFF1E7',
            border: 'none',
            borderRadius: '8px',
            padding: '0.5rem 1rem',
            cursor: 'pointer',
            fontSize: '0.875rem',
            fontWeight: 600
          }}
        >
          View All
        </button>
      </div>

      {/* Stats */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '1rem', marginBottom: '1.5rem' }}>
        <div style={{ textAlign: 'center' }}>
          <div style={{ fontSize: '1.5rem', fontWeight: 600, color: '#EF8E81' }}>
            {totalAssets}
          </div>
          <div style={{ fontSize: '0.75rem', color: '#FFF1E7', opacity: 0.7 }}>
            Assets
          </div>
        </div>
        <div style={{ textAlign: 'center' }}>
          <div style={{ fontSize: '1.5rem', fontWeight: 600, color: '#686DCA' }}>
            {totalKits}
          </div>
          <div style={{ fontSize: '0.75rem', color: '#FFF1E7', opacity: 0.7 }}>
            Branding Kits
          </div>
        </div>
        <div style={{ textAlign: 'center' }}>
          <div style={{ fontSize: '1.5rem', fontWeight: 600, color: '#5ECD7D' }}>
            {activeShares}
          </div>
          <div style={{ fontSize: '0.75rem', color: '#FFF1E7', opacity: 0.7 }}>
            Active Shares
          </div>
        </div>
      </div>

      {/* Quick Actions */}
      <div style={{ marginBottom: '1.5rem' }}>
        <h3 style={{ margin: '0 0 1rem 0', fontSize: '1rem', color: '#FFF1E7' }}>
          Quick Actions
        </h3>
        <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' }}>
          <button
            onClick={() => fileInputRef.current?.click()}
            style={{
              background: '#EF8E81',
              color: '#FFF1E7',
              border: 'none',
              borderRadius: '6px',
              padding: '0.5rem 1rem',
              cursor: 'pointer',
              fontSize: '0.875rem',
              display: 'flex',
              alignItems: 'center',
              gap: '0.5rem'
            }}
          >
            📤 Upload
          </button>
          <button
            onClick={() => {
              // Create a sample branding kit for testing
              const newKit: BrandingKit = {
                id: Date.now().toString(),
                name: 'Sample Branding Kit',
                description: 'Test branding kit created from widget',
                createdAt: new Date(),
                assets: [],
                isComplete: false,
                completionPercentage: 0
              };
              onBrandingKitsChange([...brandingKits, newKit]);
            }}
            style={{
              background: 'transparent',
              color: '#FFF1E7',
              border: '1px solid #EF8E81',
              borderRadius: '6px',
              padding: '0.5rem 1rem',
              cursor: 'pointer',
              fontSize: '0.875rem',
              display: 'flex',
              alignItems: 'center',
              gap: '0.5rem'
            }}
          >
            🎨 Create Kit
          </button>
          <button
            onClick={() => {
              // Create a sample share link for testing
              const newLink: ShareLink = {
                id: Date.now().toString(),
                name: 'Sample Share Link',
                url: 'https://example.com/share',
                isActive: true,
                createdAt: new Date(),
                expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000) // 7 days from now
              };
              onShareLinksChange([...shareLinks, newLink]);
            }}
            style={{
              background: 'transparent',
              color: '#FFF1E7',
              border: '1px solid #EF8E81',
              borderRadius: '6px',
              padding: '0.5rem 1rem',
              cursor: 'pointer',
              fontSize: '0.875rem',
              display: 'flex',
              alignItems: 'center',
              gap: '0.5rem'
            }}
          >
            🔗 Share
          </button>
        </div>
      </div>

      {/* Recent Assets */}
      <div style={{ flex: 1 }}>
        <h3 style={{ margin: '0 0 1rem 0', fontSize: '1rem', color: '#FFF1E7' }}>
          Recent Assets
        </h3>
        {recentAssets.length > 0 ? (
          <div style={{ display: 'flex', flexDirection: 'column', gap: '0.75rem' }}>
            {recentAssets.map(asset => (
              <div
                key={asset.id}
                style={{
                  display: 'flex',
                  alignItems: 'center',
                  gap: '0.75rem',
                  padding: '0.75rem',
                  background: 'rgba(255, 255, 255, 0.05)',
                  borderRadius: '8px',
                  cursor: 'pointer',
                  transition: 'all 0.2s ease'
                }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.background = 'rgba(255, 255, 255, 0.1)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.background = 'rgba(255, 255, 255, 0.05)';
                }}
              >
                <span style={{ fontSize: '1.5rem' }}>{getCategoryIcon(asset.category)}</span>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ 
                    fontSize: '0.875rem', 
                    color: '#FFF1E7', 
                    fontWeight: 500,
                    whiteSpace: 'nowrap',
                    overflow: 'hidden',
                    textOverflow: 'ellipsis'
                  }}>
                    {asset.name}
                  </div>
                  <div style={{ 
                    fontSize: '0.75rem', 
                    color: '#FFF1E7', 
                    opacity: 0.6,
                    whiteSpace: 'nowrap',
                    overflow: 'hidden',
                    textOverflow: 'ellipsis'
                  }}>
                    {formatFileSize(asset.fileSize)} • {new Date(asset.uploadDate).toLocaleDateString()}
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div style={{ 
            textAlign: 'center', 
            padding: '2rem 1rem',
            color: '#FFF1E7',
            opacity: 0.6
          }}>
            <div style={{ fontSize: '2rem', marginBottom: '0.5rem' }}>📁</div>
            <div style={{ fontSize: '0.875rem' }}>No assets yet</div>
            <div style={{ fontSize: '0.75rem', marginTop: '0.25rem' }}>
              Upload your first asset to get started
            </div>
          </div>
        )}
      </div>

      {/* Hidden file input for uploads */}
      <input
        ref={fileInputRef}
        type="file"
        multiple
        onChange={handleFileUpload}
        style={{ display: 'none' }}
      />

      {/* Quick Upload Modal */}
      {showQuickUpload && (
        <div style={{
          position: 'fixed',
          top: 0,
          left: 0,
          right: 0,
          bottom: 0,
          background: 'rgba(0, 0, 0, 0.8)',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          zIndex: 1000
        }}>
          <div style={{
            background: '#22202F',
            borderRadius: '12px',
            padding: '2rem',
            maxWidth: '400px',
            width: '90%',
            border: '1px solid rgba(255, 255, 255, 0.1)'
          }}>
            <h3 style={{ margin: '0 0 1.5rem 0', fontSize: '1.25rem', color: '#FFF1E7' }}>
              Quick Upload
            </h3>
            <input
              type="file"
              multiple
              ref={fileInputRef}
              style={{
                width: '100%',
                background: '#1A1A1A',
                border: '1px solid rgba(255, 255, 255, 0.2)',
                borderRadius: '8px',
                padding: '1rem',
                color: '#FFF1E7',
                fontSize: '1rem',
                marginBottom: '1.5rem'
              }}
              onChange={handleFileUpload}
            />
            <div style={{ display: 'flex', gap: '1rem', justifyContent: 'flex-end' }}>
              <button
                onClick={() => setShowQuickUpload(false)}
                style={{
                  background: 'transparent',
                  color: '#FFF1E7',
                  border: '1px solid #EF8E81',
                  borderRadius: '8px',
                  padding: '0.75rem 1.5rem',
                  cursor: 'pointer'
                }}
              >
                Cancel
              </button>
              <button
                onClick={() => setShowQuickUpload(false)}
                style={{
                  background: '#EF8E81',
                  color: '#FFF1E7',
                  border: 'none',
                  borderRadius: '8px',
                  padding: '0.75rem 1.5rem',
                  cursor: 'pointer',
                  fontWeight: 600
                }}
              >
                Upload
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
} 