{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/app/(.*)", "destination": "/app.html" },
    { "source": "/auth", "destination": "/app.html" },
    { "source": "/pricing", "destination": "/app.html" },
    { "source": "/checkout/(.*)", "destination": "/app.html" },
    { "source": "/feedback", "destination": "/app.html" },
    { "source": "/terms", "destination": "/app.html" },
    { "source": "/privacy", "destination": "/app.html" },
    { "source": "/affiliate-terms", "destination": "/app.html" },
    { "source": "/tracks", "destination": "/app.html" },
    { "source": "/features", "destination": "/app.html" },
    { "source": "/affiliate-partner/(.*)", "destination": "/app.html" },
    { "source": "/shared/strategy/(.*)", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}



