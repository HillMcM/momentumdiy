{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}



