{
  "weeklyWorkflow": {
    "monday": {
      "task": "Market Research",
      "agent": "Market Researcher",
      "goal": "Identify trending topics and opportunities",
      "output": "Research report with 3-5 content ideas"
    },
    "tuesday": {
      "task": "Blog Post Creation",
      "agent": "Copywriting Agent",
      "goal": "Write comprehensive blog post on selected topic",
      "output": "800-1200 word blog post saved as draft in Wix"
    },
    "wednesday": {
      "task": "Social Content Creation",
      "agent": "Social Content Agent",
      "goal": "Repurpose blog into platform-specific posts",
      "output": "4+ social posts (Facebook, Instagram, LinkedIn, X) ready for approval"
    },
    "thursdayToSunday": {
      "task": "Social Posting",
      "agent": "Social Posting Agent",
      "goal": "Post approved content at optimal times",
      "output": "Published posts across all platforms"
    }
  },
