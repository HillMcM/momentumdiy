{
  "name": "client-portal-backend",
  "version": "1.0.2",
  "description": "Backend API for Client Portal App",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "export:notion": "tsx src/scripts/notion-export.ts",
    "test-supabase-connection": "tsx src/scripts/test-supabase-connection.ts",
    "automated-notifications": "tsx src/scripts/runAutomatedNotifications.ts",
    "process-affiliate-payouts": "tsx src/scripts/processAffiliatePayouts.ts",
    "add-social-strategy-links": "tsx src/scripts/addSocialStrategyActionLinks.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "express",
    "typescript",
    "supabase",
    "api"
  ],
  "author": "MomentumDIY",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.58.0",
    "@notionhq/client": "^2.2.15",
    "@sentry/node": "^10.3.0",
    "@sentry/tracing": "^7.120.4",
    "@supabase/supabase-js": "^2.38.4",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "resend": "^6.1.0",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/morgan": "^1.9.9",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^8.54.0",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
